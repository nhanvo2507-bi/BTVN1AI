        "for var in [mat_do, khan_cap, tai_trong, giao_thong, loi_nhuan, uu_tien]:\n",
        "    var.automf(3, names=['thap', 'trung_binh', 'cao'])\n",
        "\n",
        "# Riêng Số lượng kết hợp đơn hàng có tên tập mờ là: Ít, Một số, Nhiều\n",
