        "\n",
        "\n",
        "# 1. ĐỊNH NGHĨA CÁC BIẾN\n",
        "\n",
        "# Ta dùng thang điểm 0 - 10 cho tất cả các biến để dễ mô phỏng\n",
        "\n",
        "#Các biến đầu vào (Inputs)\n",
        "mat_do = ctrl.Antecedent(np.arange(0, 11, 1), 'mat_do_don_hang')       # Mật độ đơn hàng\n",
        "khan_cap = ctrl.Antecedent(np.arange(0, 11, 1), 'muc_do_khan_cap')     # Mức độ khẩn cấp\n",
        "tai_trong = ctrl.Antecedent(np.arange(0, 11, 1), 'tai_trong_tai_xe')   # Tải trọng hiện tại\n",
        "giao_thong = ctrl.Antecedent(np.arange(0, 11, 1), 'tinh_trang_giao_thong') # Giao thông (0: thoáng, 10: tắc)\n",
        "loi_nhuan = ctrl.Antecedent(np.arange(0, 11, 1), 'loi_nhuan_moi_lan')  # Lợi nhuận\n",
        "\n",
        "#  Các biến đầu ra (Outputs)\n",
        "ket_hop = ctrl.Consequent(np.arange(0, 11, 1), 'so_luong_ket_hop')     # Số lượng kết hợp đơn hàng\n",
        "uu_tien = ctrl.Consequent(np.arange(0, 11, 1), 'muc_do_uu_tien')       # Ưu tiên giao hàng\n",
        "\n",
        "\n",
