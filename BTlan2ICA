        "#2.12\n",
        "import numpy as np\n",
        "import skfuzzy as fuzz\n",
        "from skfuzzy import control as ctrl\n",
        "import matplotlib.pyplot as plt # Bổ sung thêm thư viện vẽ đồ thị\n",
        "\n",
        "#1. ĐỊNH NGHĨA CÁC BIẾN\n",
        "\n",
        "# Đầu vào\n",
        "rating = ctrl.Antecedent(np.arange(0, 5.1, 0.1), 'rating')          # Đánh giá cửa hàng (0-5 sao)\n",
        "sales_volume = ctrl.Antecedent(np.arange(0, 101, 1), 'sales_volume') # Khối lượng bán hàng (0-100 đơn/tháng)\n",
        "profit_margin = ctrl.Antecedent(np.arange(0, 101, 1), 'profit_margin') # Biên lợi nhuận (0-100%)\n",
        "seasonal_event = ctrl.Antecedent(np.arange(0, 11, 1), 'seasonal_event') # Sự kiện mùa vụ (0-10)\n",
        "competitor_discount = ctrl.Antecedent(np.arange(0, 101, 1), 'competitor_discount') # Chiết khấu đối thủ (0-100%)\n",
        "\n",
        "# Đầu ra\n",
        "discount_rate = ctrl.Consequent(np.arange(0, 71, 1), 'discount_rate') # Tỷ lệ chiết khấu (0-70%)\n",
        "\n",
        "# 2. ĐỊNH NGHĨA TẬP MỜ\n",
        "\n",
        "# Đánh giá cửa hàng (Thấp, Trung bình, Cao)\n",
        "rating['low'] = fuzz.trimf(rating.universe, [0, 0, 4.0])\n",
        "rating['medium'] = fuzz.trimf(rating.universe, [4.0, 4.3, 4.5])\n",
        "rating['high'] = fuzz.trapmf(rating.universe, [4.5, 4.8, 5.0, 5.0])\n",
        "\n",
        "# Khối lượng bán hàng & Biên lợi nhuận & Chiết khấu đối thủ\n",
        "for var in [sales_volume, profit_margin, competitor_discount]:\n",
        "    var['low'] = fuzz.trimf(var.universe, [0, 0, 40])\n",
        "    var['medium'] = fuzz.trimf(var.universe, [30, 50, 70])\n",
        "    var['high'] = fuzz.trapmf(var.universe, [60, 80, 100, 100])\n",
        "\n",
        "# Sự kiện mùa vụ (Không có, Trung bình, Cao)\n",
        "seasonal_event['none'] = fuzz.trimf(seasonal_event.universe, [0, 0, 3])\n",
        "seasonal_event['medium'] = fuzz.trimf(seasonal_event.universe, [2, 5, 8])\n",
        "seasonal_event['high'] = fuzz.trapmf(seasonal_event.universe, [7, 9, 10, 10])\n",
        "\n",
        "# Tỷ lệ chiết khấu (Rất thấp, Thấp, Trung bình, Cao, Rất cao)\n",
        "discount_rate['very_low'] = fuzz.trimf(discount_rate.universe, [0, 0, 5])\n",
        "discount_rate['low'] = fuzz.trimf(discount_rate.universe, [5, 10, 15])\n",
        "discount_rate['medium'] = fuzz.trimf(discount_rate.universe, [10, 15, 25])\n",
        "discount_rate['high'] = fuzz.trimf(discount_rate.universe, [20, 30, 45])\n",
        "discount_rate['very_high'] = fuzz.trapmf(discount_rate.universe, [40, 55, 70, 70])\n",
        "\n",
        "#  3. HỆ THỐNG LUẬT MỜ\n",
        "\n",
        "rules = [\n",
        "    # Luật 1: Rating cao, Sales cao, Lợi nhuận cao -> Chiết khấu rất thấp\n",
        "    ctrl.Rule(rating['high'] & sales_volume['high'] & profit_margin['high'], discount_rate['very_low']),\n",
        "\n",
        "    # Luật 2: Rating thấp, Sales thấp, Lợi nhuận cao -> Chiết khấu cao (để kích cầu)\n",
        "    ctrl.Rule(rating['low'] & sales_volume['low'] & profit_margin['high'], discount_rate['high']),\n",
        "\n",
        "    # Luật 3: Sự kiện cao, Chiết khấu đối thủ cao -> Chiết khấu rất cao\n",
        "    ctrl.Rule(seasonal_event['high'] & competitor_discount['high'], discount_rate['very_high']),\n",
        "\n",
        "    # Luật 4: Rating trung bình, Sales trung bình, Lợi nhuận trung bình -> Chiết khấu trung bình\n",
        "    ctrl.Rule(rating['medium'] & sales_volume['medium'] & profit_margin['medium'], discount_rate['medium']),\n",
        "\n",
        "    # Luật 5: Đối thủ chiết khấu thấp, Lợi nhuận thấp, Sales cao -> Chiết khấu rất thấp\n",
        "    ctrl.Rule(competitor_discount['low'] & profit_margin['low'] & sales_volume['high'], discount_rate['very_low']),\n",
        "\n",
        "    # Luật 6: Rating thấp, Không có sự kiện -> Chiết khấu trung bình\n",
        "    ctrl.Rule(rating['low'] & seasonal_event['none'], discount_rate['medium']),\n",
        "\n",
        "    # Luật 7: Sales thấp, Lợi nhuận thấp -> Chiết khấu rất cao (Xả hàng/Thu hút khách)\n",
        "    ctrl.Rule(sales_volume['low'] & profit_margin['low'], discount_rate['very_high']),\n",
        "]\n",
        "\n",
        "# 4. THIẾT LẬP ĐIỀU KHIỂN & MÔ PHỎNG\n",
        "\n",
        "shopee_ctrl = ctrl.ControlSystem(rules)\n",
        "shopee_sim = ctrl.ControlSystemSimulation(shopee_ctrl)\n",
        "\n",
        "# 1. Nhập giá trị thử nghiệm\n",
        "shopee_sim.input['rating'] = 4.3\n",
        "shopee_sim.input['sales_volume'] = 50\n",
        "shopee_sim.input['profit_margin'] = 20\n",
        "shopee_sim.input['seasonal_event'] = 9\n",
        "shopee_sim.input['competitor_discount'] = 80\n",
        "\n",
        "# 2. Tính toán giải mờ\n",
        "shopee_sim.compute()\n",
        "\n",
        "# 3. In kết quả dạng text đơn giản\n",
        "ket_qua = round(shopee_sim.output['discount_rate'], 2)\n",
        "print(\"--- KẾT QUẢ ĐỀ XUẤT BÀI 2.12 ---\")\n",
        "print(\"Tỷ lệ chiết khấu đề xuất là:\", ket_qua, \"%\")\n",
        "\n",
        "# 4. Hiển thị đồ thị kết quả\n",
