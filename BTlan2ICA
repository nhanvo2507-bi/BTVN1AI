        "#2.11\n",
        "import numpy as np\n",
        "import skfuzzy as fuzz\n",
        "from skfuzzy import control as ctrl\n",
        "import matplotlib.pyplot as plt\n",
        "# 1. ĐỊNH NGHĨA CÁC BIẾN (ĐÃ VIỆT HÓA)\n",
        "# Đầu vào\n",
        "khoang_cach = ctrl.Antecedent(np.arange(0, 51, 1), 'khoang_cach')      # 0-50km\n",
        "giao_thong = ctrl.Antecedent(np.arange(0, 101, 1), 'giao_thong')       # 0-100%\n",
        "nhu_cau = ctrl.Antecedent(np.arange(0, 101, 1), 'nhu_cau')             # 0-100%\n",
        "thoi_tiet = ctrl.Antecedent(np.arange(0, 11, 1), 'thoi_tiet')          # 0-10 (Tốt -> Xấu)\n",
        "dung_gio = ctrl.Antecedent(np.arange(0, 101, 1), 'dung_gio')           # 0-100%\n",
        "# Đầu ra\n",
        "gia_cuoc = ctrl.Consequent(np.arange(0, 101, 1), 'gia_cuoc')           # 0-100 (Đại diện mức giá)\n",
        "tien_thuong = ctrl.Consequent(np.arange(0, 101, 1), 'tien_thuong')     # 0-100 (Mức thưởng)\n",
        "\n",
        "# 2. ĐỊNH NGHĨA TẬP MỜ (MEMBERSHIP FUNCTIONS)\n",
        "# Khoảng cách (Ngắn, Trung bình, Dài)\n",
        "khoang_cach['ngan'] = fuzz.trimf(khoang_cach.universe, [0, 0, 8])\n",
        "khoang_cach['trung_binh'] = fuzz.trimf(khoang_cach.universe, [2, 15, 30])\n",
        "khoang_cach['dai'] = fuzz.trapmf(khoang_cach.universe, [15, 30, 50, 50])\n",
        "# Giao thông & Nhu cầu (Thấp, Trung bình, Cao)\n",
        "for var in [giao_thong, nhu_cau]:\n",
        "    var['thap'] = fuzz.trimf(var.universe, [0, 0, 40])\n",
        "    var['trung_binh'] = fuzz.trimf(var.universe, [20, 50, 80])\n",
        "    var['cao'] = fuzz.trimf(var.universe, [60, 100, 100])\n",
        "# Thời tiết (Tốt, Bình thường, Xấu)\n",
        "thoi_tiet['tot'] = fuzz.trimf(thoi_tiet.universe, [0, 0, 4])\n",
        "thoi_tiet['binh_thuong'] = fuzz.trimf(thoi_tiet.universe, [2, 5, 8])\n",
        "thoi_tiet['xau'] = fuzz.trapmf(thoi_tiet.universe, [6, 8, 10, 10])\n",
        "# Mức độ đúng giờ (Trễ, Đúng giờ, Sớm)\n",
        "dung_gio['tre'] = fuzz.trimf(dung_gio.universe, [0, 0, 50])\n",
        "dung_gio['dung_gio'] = fuzz.trimf(dung_gio.universe, [40, 60, 80])\n",
        "dung_gio['som'] = fuzz.trimf(dung_gio.universe, [70, 100, 100])\n",
        "# Giá cước (Thấp, Trung bình, Cao, Rất cao)\n",
        "gia_cuoc['thap'] = fuzz.trimf(gia_cuoc.universe, [0, 0, 30])\n",
        "gia_cuoc['trung_binh'] = fuzz.trimf(gia_cuoc.universe, [20, 50, 70])\n",
        "gia_cuoc['cao'] = fuzz.trimf(gia_cuoc.universe, [60, 80, 90])\n",
        "gia_cuoc['rat_cao'] = fuzz.trimf(gia_cuoc.universe, [80, 100, 100])\n",
        "# Tiền thưởng (Không có, Ít, Trung bình, Cao)\n",
        "tien_thuong['khong_co'] = fuzz.trimf(tien_thuong.universe, [0, 0, 20])\n",
        "tien_thuong['it'] = fuzz.trimf(tien_thuong.universe, [10, 30, 50])\n",
        "tien_thuong['trung_binh'] = fuzz.trimf(tien_thuong.universe, [40, 60, 80])\n",
        "tien_thuong['cao'] = fuzz.trimf(tien_thuong.universe, [70, 100, 100])\n",
        "\n",
        "# 3. HỆ THỐNG 20 LUẬT MỜ\n",
        "\n",
        "rules = [\n",
        "    # Các luật về Giá cước\n",
        "    ctrl.Rule(khoang_cach['ngan'] & giao_thong['thap'] & nhu_cau['thap'], gia_cuoc['thap']),\n",
        "    ctrl.Rule(khoang_cach['ngan'] & giao_thong['trung_binh'] & nhu_cau['trung_binh'], gia_cuoc['trung_binh']),\n",
        "    ctrl.Rule(khoang_cach['ngan'] & giao_thong['cao'] & nhu_cau['cao'], gia_cuoc['cao']),\n",
        "    ctrl.Rule(khoang_cach['trung_binh'] & giao_thong['trung_binh'] & thoi_tiet['tot'], gia_cuoc['trung_binh']),\n",
        "    ctrl.Rule(khoang_cach['dai'] & giao_thong['cao'] & nhu_cau['cao'], gia_cuoc['rat_cao']),\n",
        "    ctrl.Rule(khoang_cach['dai'] & giao_thong['thap'] & nhu_cau['thap'], gia_cuoc['trung_binh']),\n",
        "    ctrl.Rule(khoang_cach['trung_binh'] & giao_thong['cao'] & thoi_tiet['xau'], gia_cuoc['rat_cao']),\n",
        "    ctrl.Rule(khoang_cach['trung_binh'] & nhu_cau['thap'] & thoi_tiet['tot'], gia_cuoc['thap']),\n",
        "    ctrl.Rule(khoang_cach['dai'] & giao_thong['cao'] & thoi_tiet['xau'], gia_cuoc['rat_cao']),\n",
        "    ctrl.Rule(khoang_cach['ngan'] & giao_thong['trung_binh'] & thoi_tiet['tot'], gia_cuoc['trung_binh']),\n",
        "\n",
        "    # Các luật về Tiền thưởng\n",
        "    ctrl.Rule(thoi_tiet['xau'] & dung_gio['som'], tien_thuong['cao']),\n",
        "    ctrl.Rule(thoi_tiet['tot'] & dung_gio['som'], tien_thuong['trung_binh']),\n",
        "    ctrl.Rule(thoi_tiet['xau'] & dung_gio['tre'], tien_thuong['khong_co']),\n",
        "    ctrl.Rule(khoang_cach['dai'] & giao_thong['cao'] & dung_gio['dung_gio'], tien_thuong['cao']),\n",
        "    ctrl.Rule(khoang_cach['ngan'] & dung_gio['dung_gio'], tien_thuong['it']),\n",
        "    ctrl.Rule(giao_thong['cao'] & dung_gio['tre'], tien_thuong['khong_co']),\n",
        "    ctrl.Rule(khoang_cach['dai'] & thoi_tiet['xau'], tien_thuong['cao']),\n",
        "    ctrl.Rule(khoang_cach['ngan'] & thoi_tiet['tot'] & dung_gio['som'], tien_thuong['trung_binh']),\n",
        "    ctrl.Rule(khoang_cach['trung_binh'] & giao_thong['cao'] & dung_gio['som'], tien_thuong['cao']),\n",
        "    ctrl.Rule(khoang_cach['trung_binh'] & thoi_tiet['binh_thuong'] & dung_gio['dung_gio'], tien_thuong['trung_binh'])\n",
        "]\n",
        "\n",
        "# 4. THIẾT LẬP MÔ PHỎNG, IN KẾT QUẢ & VẼ ĐỒ THỊ\n",
        "\n",
        "he_thong = ctrl.ControlSystem(rules)\n",
        "mo_phong = ctrl.ControlSystemSimulation(he_thong)\n",
        "\n",
        "# 1. Nhập giá trị tình huống thử nghiệm\n",
        "mo_phong.input['khoang_cach'] = 15     # 15 km\n",
        "mo_phong.input['giao_thong'] = 70      # Giao thông đông (70%)\n",
        "mo_phong.input['nhu_cau'] = 80         # Nhu cầu cao (80%)\n",
        "mo_phong.input['thoi_tiet'] = 8        # Thời tiết xấu (8/10)\n",
        "mo_phong.input['dung_gio'] = 90        # Đến sớm (90%)\n",
        "\n",
        "# 2. Tính toán giải mờ\n",
        "mo_phong.compute()\n",
        "\n",
        "# 3. In kết quả gọn gàng\n",
        "ket_qua_gia_cuoc = round(mo_phong.output['gia_cuoc'], 2)\n",
        "ket_qua_tien_thuong = round(mo_phong.output['tien_thuong'], 2)\n",
        "\n",
        "print(\"--- KẾT QUẢ ĐỀ XUẤT TỪ HỆ THỐNG MỜ ---\")\n",
        "print(\"Mức giá cước dự kiến (thang điểm 100) là:\", ket_qua_gia_cuoc)\n",
        "print(\"Mức tiền thưởng dự kiến (thang điểm 100) là:\", ket_qua_tien_thuong)\n",
        "\n",
        "# 4. Hiển thị đồ thị\n",
        "gia_cuoc.view(sim=mo_phong)\n",
        "tien_thuong.view(sim=mo_phong)\n",
        "\n",
        "# Lệnh bắt buộc để giữ các cửa sổ đồ thị mở\n",
        "plt.show()"
